# ── Скопируй в .env и заполни под свой сервер ─────────────────────────────
# (для локального запуска `npm run dev` ничего заполнять не нужно)

# Домен, на который указывает A-запись VPS. Caddy выпустит на него HTTPS-сертификат.
DOMAIN=voice.example.com

# ── STUN/TURN (нужны для звонков через интернет между разными сетями) ─────
# Публичные STUN-серверы (через запятую). Хватает для простых случаев.
STUN_URLS=stun:stun.l.google.com:19302

# URL нашего собственного TURN (coturn). Обычно turn:<домен>:3478 (можно указать несколько через запятую).
TURN_URLS=turn:voice.example.com:3478

# realm для coturn — как правило тот же домен.
TURN_REALM=voice.example.com

# Общий секрет для коротко-живущих TURN-кредов. ОБЯЗАТЕЛЬНО сгенерируй свой:
#   openssl rand -hex 32
TURN_SECRET=CHANGE_ME_openssl_rand_hex_32

# Время жизни выданного TURN-креда, секунды (по умолчанию сутки).
TURN_TTL=86400

# Публичный IP VPS для coturn. Нужен, ТОЛЬКО если сервер за NAT
# (публичный IP не на сетевом интерфейсе). Иначе оставь пустым.
EXTERNAL_IP=

# Внутренний порт Node-приложения (менять обычно не нужно).
PORT=3000
